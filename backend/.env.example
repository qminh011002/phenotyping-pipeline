# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Path to the phenotyping_pipeline reference repository (read-only at runtime)
# The backend reads config.yaml and model weights from this directory.
PIPELINE_ROOT=../phenotyping_pipeline

# PostgreSQL connection string (async)
# The database must exist before running migrations.
# To start PostgreSQL with Docker:
#   docker run -d --name phenotyping-pg \
#     -e POSTGRES_DB=phenotyping \
#     -e POSTGRES_USER=postgres \
#     -e POSTGRES_PASSWORD=postgres \
#     -p 5432:5432 \
#     postgres:16-alpine
#
# Then run migrations:
#   cd backend && alembic upgrade head
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/phenotyping
